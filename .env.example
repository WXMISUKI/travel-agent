# 豆包模型配置（火山引擎，必需）
LLM_PROVIDER=ark
ARK_API_KEY=your-ark-api-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=your-endpoint-or-model-id

# 百度搜索 API（降级方案）
BAIDU_SEARCH_API_KEY=your-baidu-api-key-here

# 12306 MCP 服务地址
# 生产环境请配置为公网可访问地址（例如 https://xxx.your-domain.com）
MCP_BASE_URL=http://localhost:8000

# 日志配置
LOG_LEVEL=INFO
STREAM_DEBUG_DELAY_MS=0

# 缓存配置（秒）
CACHE_TTL=3600

# CORS 白名单（逗号分隔）
# 生产环境示例: https://your-app.vercel.app,https://www.your-domain.com
CORS_ALLOW_ORIGINS=*

# API 鉴权（建议生产开启）
API_AUTH_ENABLED=false
API_AUTH_KEY=your-strong-api-key
API_AUTH_HEADER=x-api-key

# 前端可选：本地开发可覆盖 API 地址
# 线上同域部署时无需设置
# API_BASE_URL=http://localhost:8000
